---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class:list={[
  'fixed top-0 left-0 right-0 z-[1001] transition-all duration-300',
  transparent ? 'bg-transparent text-white' : 'bg-cream/90 backdrop-blur-sm shadow-card',
]}>
  <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl">📖</span>
      <span class:list={[
        'font-display text-lg font-bold group-hover:text-terracotta transition-colors',
        transparent ? 'text-white' : 'text-warm-dark',
      ]}>
        Lesley的文学宝鉴
      </span>
    </a>

    <div class="flex items-center gap-6">
      <a
        href="/"
        class:list={[
          'font-body text-sm transition-colors hover:text-terracotta',
          currentPath === '/' ? 'text-terracotta font-bold' : transparent ? 'text-white/70' : 'text-warm-muted',
        ]}
      >
        星球地图
      </a>
      <a
        href="/authors"
        class:list={[
          'font-body text-sm transition-colors hover:text-terracotta',
          currentPath.startsWith('/authors') ? 'text-terracotta font-bold' : transparent ? 'text-white/70' : 'text-warm-muted',
        ]}
      >
        全部作家
      </a>
      <a
        href="/about"
        class:list={[
          'font-body text-sm transition-colors hover:text-terracotta',
          currentPath === '/about' ? 'text-terracotta font-bold' : transparent ? 'text-white/70' : 'text-warm-muted',
        ]}
      >
        关于
      </a>
      <a
        href="/admin"
        class:list={[
          'font-body text-sm transition-colors hover:text-terracotta',
          currentPath === '/admin' ? 'text-terracotta font-bold' : transparent ? 'text-white/70' : 'text-warm-muted',
        ]}
      >
        管理
      </a>
      <button
        id="ai-settings-btn"
        class:list={[
          'font-body text-sm transition-colors hover:text-terracotta',
          transparent ? 'text-white/70' : 'text-warm-muted',
        ]}
        title="AI 设置"
      >
        🤖
      </button>
    </div>
  </nav>
</header>

<script>
  document.getElementById('ai-settings-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-ai-settings'));
  });
</script>
